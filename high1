<title>국어 O / X 문제집 — 중앙고 120기 · 갈무리국어</title>
<style>
  :root{
    --ink:#2B1A0A; --brown:#5C3A00; --paper:#F7F5F1; --card:#FFFFFF;
    --line:#E4DED4; --text:#231C12; --sub:#6B6256;
    --green:#1A7A3A; --greenBg:#E8F3EB; --red:#C0392B; --redBg:#F7E9E7;
    --gold:#A8762B; --blue:#1A3A5C;
  }
  *{box-sizing:border-box; -webkit-tap-highlight-color:transparent;}
  html,body{margin:0; padding:0; background:var(--paper); color:var(--text);
    font-family:'Pretendard','Malgun Gothic',-apple-system,BlinkMacSystemFont,'Apple SD Gothic Neo',sans-serif;
    -webkit-font-smoothing:antialiased;}
  button{font-family:inherit; cursor:pointer; border:none; transition:all .15s;}
  button:active{transform:scale(.97);}
  @keyframes fadeUp{from{opacity:0; transform:translateY(8px);} to{opacity:1; transform:none;}}
  .fade{animation:fadeUp .28s ease both;}
  .wrap{max-width:880px; margin:0 auto; padding:0 18px 60px;}
  .wrapN{max-width:720px; margin:0 auto;}
  .band{background:var(--ink); margin:0 -18px; padding:22px 24px 20px; display:flex;
    justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8;}
  .band .l{color:#fff; font-weight:800; font-size:15px; letter-spacing:.5px;}
  .band .r{color:#C9B89A; font-weight:700; font-size:12px; letter-spacing:1px;}
  .gcard{text-align:left; background:var(--card); border:1px solid var(--line); border-radius:13px;
    padding:15px 16px; display:flex; flex-direction:column; gap:10px; width:100%;}
  .gcard:hover{border-color:var(--gold); box-shadow:0 4px 16px rgba(43,26,10,.08);}
  .oxbtn:hover{filter:brightness(.97);}
  ::-webkit-scrollbar{width:10px; height:10px;}
  ::-webkit-scrollbar-thumb{background:#d8d0c4; border-radius:6px;}
  .grid{display:grid; grid-template-columns:repeat(auto-fill,minmax(252px,1fr)); gap:12px;}
  .sticky{position:sticky; top:0; z-index:5; background:var(--paper); padding-top:16px; padding-bottom:10px;}
  .bottomNav{position:fixed; left:0; right:0; bottom:0; background:rgba(247,245,241,.96);
    border-top:1px solid var(--line); padding:12px 18px; backdrop-filter:blur(6px);}
  .hidden{display:none!important;}
</style>
