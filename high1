<script>
"use strict";
var OX_DATA = {"parts": [{"name": "문학", "groups": [{"title": "슬견설 (이규보)", "questions": [{"q": "이 작품의 갈래적 성격에 대한 이해", "lines": [{"stmt": "객관적 세계를 글쓴이의 인식으로 전달하는 교술 갈래에 속한다.", "ans": "O", "exp": "'설'은 글쓴이가 체험·관찰한 세계를 자신의 깨달음으로 전달하는 교술 갈래이다. 서정(시)·서사(소설)·극(희곡)과 구별된다."}, {"stmt": "'설(說)'은 사실(예화)을 뒤에, 의견(주제)을 앞에 두는 것이 일반적 구성이다.", "ans": "X", "exp": "설의 일반적 구성은 사실(예화)을 '앞', 의견(주제)을 '뒤'에 두는 [사실→의견] 순서이다. 앞뒤 순서가 뒤바뀌어 적절하지 않다."}, {"stmt": "개인적 체험을 보편적 깨달음으로 일반화하는 과정이 나타난다.", "ans": "O", "exp": "손님과의 개인적 문답이라는 체험에서 '모든 생명은 동등하다'는 보편적 깨달음으로 일반화하는 과정이 드러난다."}]}, {"q": "이 작품의 구성(기-승-전-결)과 변증법적 전개의 대응에 대한 분석", "lines": [{"stmt": "'기'에서 손님이 개의 죽음을, '승'에서 '나'가 이의 죽음을 안타까워한다.", "ans": "O", "exp": "'기'는 손님이 개의 죽음을 불쌍히 여기는 장면, '승'은 '나'가 이의 죽음을 안타까워하는 장면으로, 정(正)과 반(反)에 대응한다."}, {"stmt": "'전'에서 '나'가 손님의 편견을 지적하며 결론을 제시한다.", "ans": "X", "exp": "'전'은 손님이 '나를 놀리는 것이냐'며 항의하는(편견이 드러나는) 부분이고, 결론을 제시하는 것은 '결'에서 '나'가 한다. 주체와 단계가 뒤바뀌어 적절하지 않다."}, {"stmt": "'결'에서 도출되는 명제는 정과 반을 지양(止揚)한 합(合)에 해당한다.", "ans": "O", "exp": "'결'의 '모든 생명의 죽음은 동일하게 불쌍하다'는 명제는 정과 반을 단순 부정이 아니라 한 차원 높여 아우르는 지양, 곧 합(合)이다."}]}, {"q": "다음 구절에 대한 이해\n  \"열 손가락을 깨물어 보시구려. 어디 엄지손가락만 아프고 나머지는 아프지 않습디까?\"", "lines": [{"stmt": "'한 몸'은 모든 생명이 본질적으로 동등함을 떠받치는 전제로 기능한다.", "ans": "O", "exp": "손가락들이 '한 몸'에 속해 모두 아프듯, 모든 생명이 동등하다는 주장의 전제로 '한 몸'이라는 설정이 기능한다."}, {"stmt": "'엄지손가락'과 '나머지 손가락'의 통증 차이로 생명의 등급을 입증한다.", "ans": "X", "exp": "이 비유는 손가락마다 통증에 '차이가 없음'을 들어 생명에 등급이 없음을 입증하는 것이다. 통증 차이로 등급을 입증한다는 설명은 비유의 취지를 정반대로 본 것이다."}, {"stmt": "청자가 직접 해 볼 수 있는 행위를 제시해 주장의 즉각적 수긍을 노린다.", "ans": "O", "exp": "'깨물어 보시구려'처럼 청자가 직접 해 볼 수 있는 행위를 제시하여 주장을 즉각 체감·수긍하게 만든다."}]}, {"q": "다음 구절의 표현 방식에 대한 이해\n  \"어찌 꼭 큰 생물만이 죽음을 싫어하고, 작은 생물은 그렇지 않다 하겠소?\"", "lines": [{"stmt": "표면적 진술과 속뜻이 반대인 반어법이 사용되었다.", "ans": "X", "exp": "이 구절은 표면과 속뜻이 반대인 반어법이 아니라, 의문 형식으로 단정을 강조하는 설의법이다. 표면의 의문이 곧 '작은 생물도 죽음을 싫어한다'는 속뜻과 어긋나지 않는다."}, {"stmt": "의문형 종결을 통해 단정적 진술보다 강한 인상을 남긴다.", "ans": "O", "exp": "'~하겠소?'라는 의문형 종결은 평이한 단정보다 독자의 사고를 자극하여 더 강한 인상을 남긴다."}, {"stmt": "앞 구절에서 제시한