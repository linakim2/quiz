var FLAT = [], GROUPS = [];
(function(){
  OX_DATA.parts.forEach(function(p, pi){
    p.groups.forEach(function(g, gi){
      var gid = pi+"-"+gi;
      var items = [];
      g.questions.forEach(function(q, qi){
        var it = {partName:p.name, partIdx:pi, groupTitle:g.title, groupIdx:gi,
                  q:q.q, lines:q.lines, gid:gid};
        FLAT.push(it); items.push(it);
      });
      GROUPS.push({gid:gid, partName:p.name, partIdx:pi, title:g.title,
        count:items.length,
        stmtCount:items.reduce(function(s,it){return s+it.lines.length;},0)});
    });
  });
