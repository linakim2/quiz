  pr.appendChild(barOut);
  var statLine = el("div",{style:"margin-top:12px; display:flex; gap:18px; font-size:13px;"});
  statLine.appendChild(el("span",{style:"color:"+C.sub+";", html:"누적 정답률 <b style='color:"+(overallPct>=70?C.green:C.red)+"; font-size:16px;'>"+overallPct+"%</b>"}));
  if(ansStmt>0) statLine.appendChild(el("span",{style:"color:"+C.sub+";", html:"맞힌 진술 <b style='color:"+C.ink+";'>"+gotStmt+"</b>/"+ansStmt}));
  pr.appendChild(statLine);
  prog.appendChild(pr);
  if(doneCount>0){
    prog.appendChild(el("button",{style:"background:transparent; color:"+C.sub+"; font-size:12px; padding:7px 12px; border:1px solid "+C.line+"; border-radius:8px;",
      onclick:function(){ if(confirm("저장된 점수와 진행 기록을 모두 지울까요?")){ STORE={}; saveStore(STORE); render(); } }},"기록 초기화"));
  }
  root.appendChild(prog);

  // 파트별 단원
  var byPart = {};
  GROUPS.forEach(function(g){ (byPart[g.partName]=byPart[g.partName]||[]).push(g); });
  Object.keys(byPart).forEach(function(pname){
    var gs = byPart[pname];
    var sec = el("div",{style:"margin-bottom:30px;"});
    sec.appendChild(el("div",{style:"display:flex; align-items:center; gap:10px; margin-bottom:14px;"},[
      el("span",{style:"background:"+C.ink+"; color:#fff; font-size:13px; font-weight:800; padding:5px 12px; border-radius:7px;"}, pname),
      el("span",{style:"color:"+C.sub+"; font-size:13px;"}, gs.length+"단원"),
      el("div",{style:"flex:1; height:1px; background:"+C.line+";"})
    ]));
    var grid = el("div",{class:"grid"});
    gs.forEach(function(g){
      var r = STORE[g.gid];
      var pct = r? Math.round(r.correct/r.total*100):null;
      var card = el("button",{class:"gcard fade", onclick:(function(gid){return function(){ startGroup(gid); };})(g.gid)});
      var top = el("div",{style:"display:flex; justify-content:space-between; align-items:flex-start; gap:8px;"});
      top.appendChild(el("span",{style:"font-weight:700; font-size:14.5px; color:"+C.text+"; line-height:1.4;"}, g.title));
      if(r){
        var badgeCol = pct>=70?C.green:(pct>=40?C.gold:C.red);
        top.appendChild(el("span",{style:"flex-shrink:0; font-size:11px; font-weight:800; color:#fff; background:"+badgeCol+"; padding:3px 8px; border-radius:20px;"}, pct+"%"));
      }
      card.appendChild(top);
      card.appendChild(el("div",{style:"display:flex; justify-content:space-between; align-items:center;"},[
        el("span",{style:"font-size:12px; color:"+C.sub+";"}, g.count+"문항 · "+g.stmtCount+"진술"),
        el("span",{style:"font-size:12px; font-weight:700; color:"+(r?C.gold:C.brown)+";"}, r?"다시 풀기 →":"풀기 →")
      ]));
      grid.appendChild(card);
    });
    sec.appendChild(grid);
    root.appendChild(sec);
  });

  root.appendChild(el("div",{style:"text-align:center; color:"+C.sub+"; font-size:12px; margin-top:30px; padding-top:20px; border-top:1px solid "+C.line+";"},
    "MADE BY BLACK CAPTAIN NO.1 · 갈무리국어"));
  return root;
}

function Ring(pct, label, sub){
  var r=30, circ=2*Math.PI*r;
  var wrap = el("div",{style:"position:relative; width:78px; height:78px; flex-shrink:0;"});
  var ns="http://www.w3.org/2000/svg";
  var svg=document.createElementNS(ns,"svg"); svg.setAttribute("width","78"); svg.setAttribute("height","78");
  svg.setAttribute("style","transform:rotate(-90deg);");
  var c1=document.createElementNS(ns,"circle");
  ["cx","39","cy","39","r",r,"fill","none","stroke","#EFEAE1","stroke-width","7"].forEach(function(v,i,a){ if(i%2===0) c1.setAttribute(a[i],a[i+1]); });
  var c2=document.createElementNS(ns,"circle");
  var attrs2={cx:39,cy:39,r:r,fill:"none",stroke:C.gold,"stroke-width":7,"stroke-linecap":"round","stroke-dasharray":circ,"stroke-dashoffset":circ*(1-pct/100)};
  for(var k in attrs2) c2.setAttribute(k, attrs2[k]);
  c2.setAttribute("style","transition:stroke-dashoffset .6s;");
  svg.appendChild(c1); svg.appendChild(c2);
  wrap.appendChild(svg);
  wrap.appendChild(el("div",{style:"position:absolute; inset:0; display:flex; flex-direction:column; align-items:center; justify-content:center;"},[
    el("span",{style:"font-weight:800; font-size:15px; color:"+C.ink+";"}, label),
    el("span",{style:"font-size:10px; color:"+C.sub+";"}, sub)
  ]));
  return wrap;
}

/* ---------- 퀴즈 ---------- */
function startGroup(gid){
  STATE.gid = gid;
  STATE.qi = 0;
  var items = itemsOf(gid);
  STATE.answers = items.map(function(it){ return it.lines.map(function(){return undefined;}); });
  go("quiz");
}

function Quiz(){
  var group = GROUPS.filter(function(g){return g.gid===STATE.gid;})[0];
  var items = itemsOf(STATE.gid);
  var answers = STATE.answers;
  var qi = STATE.qi;
  var cur = items[qi];
  var totalStmt = items.reduce(function(s,it){return s+it.lines.length;},0);
  var answeredStmt = answers.reduce(function(s,a){return s+a.filter(Boolean).length;},0);
  var curDone = answers[qi].every(Boolean);
  var allDone = answers.every(function(a){return a.every(Boolean);});

  var root = el("div",{class:"wrapN fade", style:"padding:0 18px 120px;"});

  // 상단바
  var sticky = el("div",{class:"sticky"});
  var topRow = el("div",{style:"display:flex; align-items:center; gap:12px; margin-bottom:12px;"});
  topRow.appendChild(el("button",{style:"background:transparent; color:"+C.sub+"; font-size:20px; padding:2px 8px; border-radius:8px;",
    onclick:function(){ go("home"); }},"\u2039"));
  topRow.appendChild(el("div",{style:"flex:1;"},[
    el("div",{style:"font-size:11px; color:"+C.gold+"; font-weight:700; letter-spacing:1px;"}, group.partName),
    el("div",{style:"font-size:15px; font-weight:800; color:"+C.ink+";"}, group.title)
  ]));
  topRow.appendChild(el("div",{style:"font-size:13px; color:"+C.sub+"; font-weight:700;"}, (qi+1)+" / "+items.length));
  sticky.appendChild(topRow);
  var pbar = el("div",{style:"height:7px; background:#EFEAE1; border-radius:5px; overflow:hidden;"});
  pbar.appendChild(el("div",{style:"width:"+(answeredStmt/totalStmt*100)+"%; height:100%; background:linear-gradient(90deg,"+C.brown+","+C.gold+"); border-radius:5px; transition:width .3s;"}));
  sticky.appendChild(pbar);
  root.appendChild(sticky);

  // 문항 카드
  var card = el("div",{class:"fade", style:"background:"+C.card+"; border:1px solid "+C.line+"; border-radius:16px; padding:22px 20px; margin-top:14px;"});
  card.appendChild(el("div",{style:"display:flex; gap:10px; align-items:baseline; margin-bottom:18px;"},[
    el("span",{style:"font-size:22px; font-weight:900; color:"+C.gold+"; line-height:1;"}, String(qi+1)),
    el("span",{style:"font-size:16.5px; font-weight:800; color:"+C.ink+"; line-height:1.5; white-space:pre-line;"}, cur.q)
  ]));
  var lineWrap = el("div",{style:"display:flex; flex-direction:column; gap:14px;"});
  cur.lines.forEach(function(ln, li){
    var box = el("div",{style: li>0?"border-top:1px solid "+C.line+"; padding-top:14px;":""});
    box.appendChild(el("div",{style:"display:flex; gap:8px; margin-bottom:11px;"},[
      el("span",{style:"font-weight:800; color:"+C.brown+"; font-size:15px; flex-shrink:0;"}, MARKS[li]+"."),
      el("span",{style:"font-size:15.5px; color:"+C.text+"; line-height:1.55;"}, ln.stmt)
    ]));
    var btnRow = el("div",{style:"display:flex; gap:10px; padding-left:22px;"});
    ["O","X"].forEach(function(v){
      var on = answers[qi][li]===v;
      var isO = v==="O";
      var b = el("button",{class:"oxbtn",
        style:"flex:1; max-width:130px; padding:11px 0; border-radius:11px; font-size:18px; font-weight:900;"
          +"border:"+(on?("2px solid "+(isO?C.green:C.red)):("1.5px solid "+C.line))+";"
          +"background:"+(on?(isO?C.greenBg:C.redBg):C.card)+";"
          +"color:"+(on?(isO?C.green:C.red):"#B7AE9F")+";",
        onclick:(function(li,v){return function(){ STATE.answers[STATE.qi][li]=v; render(); };})(li,v)
      }, v);
      btnRow.appendChild(b);
    });
    box.appendChild(btnRow);
    lineWrap.appendChild(box);
  });
  card.appendChild(lineWrap);
  root.appendChild(card);

  // 문항 점프 dots
  var dots = el("div",{style:"display:flex; flex-wrap:wrap; gap:7px; justify-content:center; margin-top:20px;"});
  items.forEach(function(_, i){
    var done = answers[i].every(Boolean);
    dots.appendChild(el("button",{
      style:"width:26px; height:26px; border-radius:8px; font-size:11px; font-weight:700;"
        +"border:"+(i===qi?("2px solid "+C.ink):("1px solid "+C.line))+";"
        +"background:"+(done?C.ink:C.card)+"; color:"+(done?"#fff":C.sub)+";",
      onclick:(function(i){return function(){ STATE.qi=i; render(); window.scrollTo(0,0); };})(i)
    }, String(i+1)));
  });
  root.appendChild(dots);

  // 하단 네비
  var nav = el("div",{class:"bottomNav"});
  var navIn = el("div",{class:"wrapN", style:"display:flex; gap:10px; align-items:center;"});
  navIn.appendChild(el("button",{
    style:"padding:12px 18px; border-radius:11px; font-weight:700; font-size:14px;"
      +"background:"+C.card+"; border:1px solid "+C.line+"; color:"+(qi===0?"#C8C0B3":C.text)+"; opacity:"+(qi===0?".5":"1")+";",
    onclick:function(){ if(STATE.qi>0){ STATE.qi--; render(); window.scrollTo(0,0); } }
  },"이전"));
  if(qi < items.length-1){
    navIn.appendChild(el("button",{
      style:"flex:1; padding:13px 0; border-radius:11px; font-weight:800; font-size:15px; color:#fff;"
        +"background:"+(curDone?C.ink:"#CDBFA6")+";",
      onclick:function(){ STATE.qi++; render(); window.scrollTo(0,0); }
    },"다음 문제"));
  } else {
    navIn.appendChild(el("button",{
      style:"flex:1; padding:13px 0; border-radius:11px; font-weight:800; font-size:15px; color:#fff;"
        +"background:"+(allDone?("linear-gradient(90deg,"+C.brown+","+C.gold+")"):"#CDBFA6")+";",
      onclick:function(){ if(allDone) submitQuiz(); }
    }, allDone?"채점하기":((totalStmt-answeredStmt)+"개 더 풀기")));
  }
  nav.appendChild(navIn);
  root.appendChild(nav);
  return root;
}

function submitQuiz(){
  var items = itemsOf(STATE.gid);
  var answers = STATE.answers;
  var correct=0, total=0;
  var detail = items.map(function(it, i){
    return it.lines.map(function(ln, j){
      total++;
      var ok = answers[i][j]===ln.ans;
      if(ok) correct++;
      return { picked:answers[i][j], ans:ln.ans, ok:ok };
    });
  });
  STORE[STATE.gid] = { correct:correct, total:total, detail:detail, ts:Date.now() };
  saveStore(STORE);
  go("result");
}

/* ---------- 결과 ---------- */
function Result(){
  var group = GROUPS.filter(function(g){return g.gid===STATE.gid;})[0];
  var result = STORE[STATE.gid];
  var items = itemsOf(STATE.gid);
  if(!result){ go("home"); return el("div"); }
  var pct = Math.round(result.correct/result.total*100);
  var grade = pct>=90?"완벽해요":(pct>=70?"잘했어요":(pct>=50?"조금 더!":"복습이 필요해요"));
  var gColor = pct>=70?C.green:(pct>=50?C.gold:C.red);

  var root = el("div",{class:"wrapN fade", style:"padding:0 18px 80px;"});

  // 점수 헤더
  var head = el("div",{style:"background:"+C.ink+"; margin:0 -18px; padding:30px 24px 26px; text-align:center;"});
  head.appendChild(el("div",{style:"font-size:12px; color:#C9B89A; font-weight:700; letter-spacing:1px; margin-bottom:4px;"}, group.partName+" · "+group.title));
  head.appendChild(el("div",{style:"font-size:13px; color:#9C8A6E; margin-bottom:14px;"},"채점 결과"));
  head.appendChild(el("div",{style:"display:flex; justify-content:center; align-items:baseline; gap:4px;"},[
    el("span",{style:"font-size:56px; font-weight:900; color:#fff; line-height:1;"}, String(pct)),
    el("span",{style:"font-size:22px; font-weight:800; color:#C9B89A;"},"%")
  ]));
  var gradeCol = gColor===C.red?"#E8A99F":(gColor===C.gold?"#E0C58A":"#9FD9B0");
  head.appendChild(el("div",{style:"margin-top:8px; color:"+gradeCol+"; font-weight:800; font-size:15px;"}, grade));
  head.appendChild(el("div",{style:"margin-top:6px; color:#B7A88C; font-size:13px;"}, result.correct+" / "+result.total+" 진술 정답"));
  root.appendChild(head);

  root.appendChild(resultBtns(group));

  root.appendChild(el("div",{style:"font-size:14px; font-weight:800; color:"+C.ink+"; margin-bottom:12px;"},"문항별 해설"));
  var list = el("div",{style:"display:flex; flex-direction:column; gap:14px;"});
  items.forEach(function(it, i){
    var d = result.detail[i];
    var allOk = d.every(function(x){return x.ok;});
    var qcard = el("div",{style:"background:"+C.card+"; border:1px solid "+C.line+"; border-left:4px solid "+(allOk?C.green:C.red)+"; border-radius:12px; padding:15px 16px;"});
    qcard.appendChild(el("div",{style:"display:flex; gap:8px; align-items:baseline; margin-bottom:12px;"},[
      el("span",{style:"font-weight:900; color:"+C.gold+"; font-size:15px;"}, String(i+1)),
      el("span",{style:"font-weight:800; color:"+C.ink+"; font-size:14.5px; line-height:1.5; white-space:pre-line;"}, it.q)
    ]));
    var lw = el("div",{style:"display:flex; flex-direction:column; gap:10px;"});
    it.lines.forEach(function(ln, j){
      var dd = d[j];
      var row = el("div",{style:"display:flex; gap:9px;"});
      row.appendChild(el("span",{style:"flex-shrink:0; width:20px; height:20px; border-radius:6px; font-size:12px; font-weight:800; display:flex; align-items:center; justify-content:center; margin-top:2px;"
        +"background:"+(dd.ok?C.greenBg:C.redBg)+"; color:"+(dd.ok?C.green:C.red)+";"}, dd.ok?"\u2713":"\u2715"));
      var rc = el("div",{style:"flex:1;"});
      rc.appendChild(el("div",{style:"font-size:14px; color:"+C.text+"; line-height:1.5;",
        html:"<b style='color:"+C.brown+";'>"+MARKS[j]+".</b> "+escapeHtml(ln.stmt)}));
      var meta = "정답 <b style='color:"+(ln.ans==="O"?C.green:C.red)+";'>"+ln.ans+"</b>";
      if(!dd.ok && dd.picked) meta += " · 내 답 <b style='color:"+C.red+";'>"+dd.picked+"</b>";
      rc.appendChild(el("div",{style:"font-size:12.5px; margin-top:3px; color:"+C.sub+";", html:meta}));
      rc.appendChild(el("div",{style:"font-size:13px; margin-top:6px; color:"+C.text+"; line-height:1.6; background:"+C.paper+"; border-radius:8px; padding:8px 11px;"}, ln.exp));
      row.appendChild(rc);
      lw.appendChild(row);
    });
    qcard.appendChild(lw);
    list.appendChild(qcard);
  });
  root.appendChild(list);
  root.appendChild(resultBtns(group, true));
  return root;
}

function resultBtns(group, bottom){
  var wrap = el("div",{style:"display:flex; gap:10px; margin:"+(bottom?"24px 0 0":"18px 0 26px")+";"});
  wrap.appendChild(el("button",{
    style:"flex:1; padding:13px 0; border-radius:11px; font-weight:800; font-size:14.5px; background:"+C.card+"; border:1.5px solid "+C.brown+"; color:"+C.brown+";",
    onclick:function(){ startGroup(group.gid); }
  },"다시 풀기"));
  wrap.appendChild(el("button",{
    style:"flex:1; padding:13px 0; border-radius:11px; font-weight:800; font-size:14.5px; background:"+C.ink+"; color:#fff;",
    onclick:function(){ go("home"); }
  },"단원 목록"));
  return wrap;
}

function escapeHtml(s){
  return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;");
}

/* ---------- 시작 ---------- */
render();
</script>
</body>
</html>
